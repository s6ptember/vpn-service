# One .env for the whole stack. The app reads it through env_file and through the build-time secret
# mount; caddy, marzban and both marzban one-shots read it through ${...} interpolation in
# docker-compose.yml. There is no second env file.
#
# The domain is spelled four times below. That is unavoidable — PUBLIC_APP_URL and
# MARZBAN_SUB_URL_PREFIX are frozen into the app image at build time and cannot be interpolated —
# so marzban-init compares all four before anything boots and refuses to start on a mismatch.

# ── deploy ──────────────────────────────────────────────────────────────────────────────────────
# Both need a live A/AAAA record pointing at this VPS BEFORE the first `docker compose up`: caddy
# asks Let's Encrypt for a certificate the moment it starts, and failed authorisations are
# rate-limited.
APP_DOMAIN=app.example.com
SUB_DOMAIN=sub.example.com
ACME_EMAIL=admin@example.com
# Uncomment while DNS is still propagating — staging has far looser rate limits and issues
# certificates no browser trusts, which is exactly what you want for a dry run.
# ACME_CA=https://acme-staging-v02.api.letsencrypt.org/directory

# ── app ─────────────────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PUBLIC_APP_URL=https://app.example.com
DATABASE_PATH=/data/app.db
SESSION_SECRET=            # openssl rand -hex 32
SESSION_TTL_DAYS=7
ADDRESS_HEADER=x-forwarded-for  # read by adapter-node; without it every request looks like Caddy's IP
XFF_DEPTH=1                     # last X-Forwarded-For entry — the one Caddy appends, not the client

# ── telegram ────────────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=   # header X-Telegram-Bot-Api-Secret-Token
ADMIN_CHAT_ID=             # chat id админа ВПН, он же единственный админ панели
INIT_DATA_MAX_AGE_SEC=86400

# ── marzban ─────────────────────────────────────────────────────────────────────────────────────
MARZBAN_API_URL=http://marzban:8000
# The account the APP authenticates with. marzban-init creates it as NON-SUDO on first boot
# (CLAUDE.md 2): a superadmin token would make every app-side bug a panel-wide one.
# Max 72 bytes — bcrypt refuses anything longer.
#   openssl rand -hex 24
MARZBAN_ADMIN_USERNAME=vpnapp
MARZBAN_ADMIN_PASSWORD=
# The operator's dashboard account, created as sudo. Optional — leave both empty to skip it. The
# dashboard is never published: reach it over an SSH tunnel to the docker network.
#   ssh -L 8000:127.0.0.1:8000 user@vps   (with a host-side forward onto the marzban container)
MARZBAN_SUDO_USERNAME=
MARZBAN_SUDO_PASSWORD=
# Must byte-match a `tag` in the panel's xray config, spaces included, or every POST /api/user
# answers 422. marzban-init compares the two and refuses to start on a mismatch.
MARZBAN_INBOUND_TAGS=VLESS TCP REALITY
MARZBAN_VLESS_FLOW=xtls-rprx-vision
MARZBAN_SUB_URL_PREFIX=https://sub.example.com

# ── xray / reality ──────────────────────────────────────────────────────────────────────────────
# Rendered into the panel's xray config by marzban-init on first boot, then never touched again.
#
# The port is published as-is and copied verbatim into every subscription link. It is 8443 and not
# 443 because caddy already owns 443 on this host; moving REALITY to 443 needs a second host IP.
REALITY_PORT=8443
# The site REALITY impersonates. It must answer TLS 1.3 with X25519 and offer h2, must not sit
# behind a third-party CDN, and must not be hosted in the same country as this VPS. `serverNames`
# entries are matched exactly — this Xray build supports no wildcards — and must be on the dest's
# certificate. Alternatives that pass the same checks: dl.google.com:443, www.cisco.com:443.
REALITY_DEST=gateway.icloud.com:443
REALITY_SERVER_NAMES=gateway.icloud.com
# Leave both empty and marzban-init generates them once, keeping them on the marzban-data volume.
# Fill them only to pin keys you generated yourself:
#   docker run --rm gozargah/marzban:v0.8.4 xray x25519
#   openssl rand -hex 8
# Changing either after the first boot cuts off every client already issued.
REALITY_PRIVATE_KEY=
REALITY_SHORT_ID=

# ── payments ────────────────────────────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=stripe            # stripe | fake
STRIPE_SECRET_KEY=                 # sk_live_… / sk_test_…
STRIPE_WEBHOOK_SECRET=             # whsec_… из stripe listen или из дашборда
PRICE_CURRENCY=usd                 # ISO 4217 в нижнем регистре, как требует Stripe
RETURN_DEEPLINK=https://t.me/<bot_username>/<app_short_name>

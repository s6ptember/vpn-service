# Marzban's own environment, separate from the app's .env. Copy before the first boot:
#   cp marzban/.env.example marzban/.env
# Variable names verified against upstream Gozargah/Marzban v0.8.4 .env.example.
#
# XRAY_SUBSCRIPTION_URL_PREFIX and XRAY_SUBSCRIPTION_PATH are NOT here on purpose: docker-compose.yml
# sets them, because Caddy's /sub/* route and the QR both break silently if they drift.

# Panel superadmin, created on first boot.
#
# This is NOT the account the app authenticates with. CLAUDE.md 2 requires the app to use a
# separate non-sudo API account: boot the panel once, create that account with
#   docker compose exec marzban marzban cli admin create --username <name>
# and put its credentials in the app's MARZBAN_ADMIN_USERNAME / MARZBAN_ADMIN_PASSWORD.
# Handing the app a superadmin token makes every app-side bug a panel-wide one.
SUDO_USERNAME=
SUDO_PASSWORD=

# Bound inside the docker network only. Port 8000 is never published (tech.md 3).
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000

# The panel is not public, so its API docs have no audience but an attacker.
DOCS=false
DEBUG=false

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLALCHEMY_DATABASE_URL and XRAY_JSON are left at their image defaults, which already resolve
# under /var/lib/marzban — the marzban-data volume. Override only if you move the data dir.
